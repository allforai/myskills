{
  "mcpServers": {
    "openrouter": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-openrouter/dist/index.js"],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      }
    },
    "stitch": {
      "command": "npx",
      "args": ["-y", "@_davideast/stitch-mcp", "proxy"],
      "env": {}
    }
  }
}
