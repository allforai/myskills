{
  "schema_version": "1.0",
  "mission": "面向远程设计团队的实时协作白板，融合 AI 辅助设计能力",
  "target_market": "10-200人的远程/混合设计团队，月均协作工具预算 $50-200/人",
  "features": [
    "无限画布（缩放、平移、网格对齐）",
    "基础绘图工具（画笔、形状、文本、箭头、便签）",
    "实时多人协作（光标同步、冲突解决、在线状态）",
    "图片/PDF 导入与标注",
    "组件库（可复用的设计元素，团队共享）",
    "模板系统（会议、头脑风暴、用户旅程、架构图模板）",
    "评论与反馈（锚点评论、@提及、线程回复）",
    "版本历史（快照、回滚、分支对比）",
    "导出功能（PNG/SVG/PDF，分享链接）",
    "AI 辅助（智能排版、手绘转矢量、自动配色建议）",
    "团队管理（成员邀请、角色权限、项目空间）",
    "第三方集成（Figma 导入、Slack 通知、Jira 卡片嵌入）",
    "离线模式（断网编辑、重连后自动合并）",
    "演示模式（全屏演示、激光笔、步骤导航）"
  ],
  "errc_highlights": {
    "must_have": [
      "无限画布",
      "基础绘图工具",
      "实时多人协作",
      "导出功能",
      "团队管理"
    ],
    "differentiators": [
      "AI 辅助（智能排版、手绘转矢量、自动配色建议）",
      "组件库（团队共享设计元素）"
    ],
    "eliminate": [
      "视频会议（用现有工具 Zoom/Meet）",
      "项目管理功能（用 Jira/Linear）",
      "代码编辑器"
    ]
  },
  "roles": [
    { "id": "R1", "name": "设计师", "app": "web-app", "client_type": "react-spa", "high_frequency_tasks": ["绘图", "标注", "评论"] },
    { "id": "R2", "name": "产品经理", "app": "web-app", "client_type": "react-spa", "high_frequency_tasks": ["评论", "模板使用", "演示"] },
    { "id": "R3", "name": "团队管理员", "app": "web-app", "client_type": "react-spa", "high_frequency_tasks": ["成员管理", "权限设置", "账单"] },
    { "id": "R4", "name": "访客", "app": "web-app", "client_type": "react-spa", "high_frequency_tasks": ["查看", "评论"] }
  ],
  "mvp_features": [
    "无限画布",
    "基础绘图工具",
    "实时多人协作",
    "导出功能",
    "团队管理",
    "评论与反馈"
  ],
  "post_launch_features": [
    "AI 辅助",
    "组件库",
    "模板系统",
    "版本历史",
    "图片/PDF 导入与标注",
    "第三方集成",
    "离线模式",
    "演示模式"
  ]
}
