{
  "schema_version": "1.0",
  "mission": "全品类跨境电商平台——连接全球卖家与消费者，提供从商品发现到履约的端到端体验",
  "target_market": "全球消费者 + 中小型跨境卖家，日均订单目标 100 万+",
  "business_domains": ["marketplace", "logistics", "payments", "advertising", "seller-tools", "customer-service"],
  "features": [
    "商品搜索与推荐（全文搜索、个性化推荐、搜索建议、筛选排序）",
    "商品详情页（图片/视频、规格参数、价格、库存、评价摘要）",
    "购物车（多卖家合并、满减计算、库存锁定）",
    "结算与支付（多币种、多支付方式、分期付款、优惠券叠加）",
    "订单管理（状态追踪、取消、退款、换货、纠纷仲裁）",
    "物流追踪（多段物流、跨境清关状态、预计到达时间）",
    "用户评价系统（文字+图片+视频评价、卖家回复、评价排序）",
    "会员体系（Prime 类会员、积分、等级权益、专属价格）",
    "消息中心（订单通知、促销推送、客服消息、系统公告）",
    "客服系统（智能客服 AI、人工客服转接、工单管理）",
    "卖家入驻与审核（资质审核、保证金、合同签署）",
    "卖家商品管理（批量上架、SKU 管理、库存同步、价格策略）",
    "卖家订单履约（发货管理、物流对接、退货处理）",
    "卖家数据看板（销售分析、流量分析、转化率、库存预警）",
    "卖家广告系统（关键词竞价、展示广告、ROI 分析）",
    "平台运营后台（类目管理、活动配置、banner 管理、规则引擎）",
    "促销引擎（限时秒杀、满减、跨店满减、优惠券、拼团）",
    "风控系统（刷单检测、虚假评价识别、账号异常检测）",
    "内容社区（种草笔记、直播带货、短视频）",
    "国际化（多语言、多币种、多时区、本地化合规）",
    "搜索广告（搜索结果中的付费推广位）",
    "仓储管理（FBA 类代发货、库存调拨、退货入库）",
    "供应链金融（卖家贷款、账期管理、结算周期）",
    "数据平台（用户行为追踪、A/B 测试、推荐模型训练）",
    "开放平台 API（第三方 ERP/WMS 对接、OAuth2、Webhook）",
    "合规与审计（GDPR、税务计算、跨境合规文档）"
  ],
  "errc_highlights": {
    "must_have": [
      "商品搜索与推荐",
      "商品详情页",
      "购物车",
      "结算与支付",
      "订单管理",
      "物流追踪",
      "卖家入驻与审核",
      "卖家商品管理",
      "卖家订单履约",
      "平台运营后台"
    ],
    "differentiators": [
      "AI 智能客服",
      "个性化推荐引擎",
      "跨境一站式物流"
    ],
    "eliminate": [
      "自营商品（纯平台模式）",
      "线下门店",
      "金融理财产品"
    ]
  },
  "roles": [
    { "id": "R1", "name": "消费者", "app": "buyer-app", "client_type": "react-native", "high_frequency_tasks": ["搜索", "浏览", "下单", "追踪物流"] },
    { "id": "R2", "name": "卖家", "app": "seller-portal", "client_type": "react-spa", "high_frequency_tasks": ["商品管理", "订单处理", "数据分析"] },
    { "id": "R3", "name": "平台运营", "app": "ops-admin", "client_type": "react-spa", "high_frequency_tasks": ["类目管理", "活动配置", "审核"] },
    { "id": "R4", "name": "客服专员", "app": "cs-workbench", "client_type": "react-spa", "high_frequency_tasks": ["工单处理", "纠纷仲裁", "退款审批"] },
    { "id": "R5", "name": "仓储操作员", "app": "wms-app", "client_type": "react-native", "high_frequency_tasks": ["入库", "出库", "盘点", "退货处理"] },
    { "id": "R6", "name": "财务", "app": "finance-admin", "client_type": "react-spa", "high_frequency_tasks": ["结算对账", "发票管理", "税务报表"] },
    { "id": "R7", "name": "广告主（卖家子角色）", "app": "ad-console", "client_type": "react-spa", "high_frequency_tasks": ["创建广告", "出价调整", "ROI 分析"] },
    { "id": "R8", "name": "数据分析师", "app": "data-platform", "client_type": "react-spa", "high_frequency_tasks": ["报表查询", "A/B 测试", "模型监控"] }
  ],
  "mvp_features": [
    "商品搜索与推荐",
    "商品详情页",
    "购物车",
    "结算与支付",
    "订单管理",
    "物流追踪",
    "卖家入驻与审核",
    "卖家商品管理",
    "卖家订单履约",
    "平台运营后台",
    "消息中心",
    "用户评价系统"
  ],
  "post_launch_features": [
    "会员体系",
    "客服系统",
    "卖家数据看板",
    "卖家广告系统",
    "促销引擎",
    "风控系统",
    "内容社区",
    "国际化",
    "搜索广告",
    "仓储管理",
    "供应链金融",
    "数据平台",
    "开放平台 API",
    "合规与审计"
  ]
}
