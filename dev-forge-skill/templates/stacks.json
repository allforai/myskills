  "sub_project_types": [
    {
      "id": "backend",
      "name": "API 后端",
      "description": "无 UI，API 设计 / 数据模型 / 业务逻辑 / 中间件",
      "compatible_stacks": ["nestjs-typeorm", "spring-boot-jpa", "flask-sqlalchemy", "django-rest", "go-gin", "rails-postgres", "laravel", "fastapi"]
    },
    {
      "id": "admin",
      "name": "管理后台",
      "description": "CRUD 界面、数据表格、表单、图表、权限管理",
      "compatible_stacks": ["nextjs", "nuxt", "angular", "sveltekit", "vite-react", "vite-vue"]
    },
    {
      "id": "web-customer",
      "name": "消费者 Web",
      "description": "SEO、性能 (Core Web Vitals)、无障碍、i18n",
      "compatible_stacks": ["nextjs", "nuxt", "sveltekit", "vite-react", "vite-vue"]
    },
    {
      "id": "web-mobile",
      "name": "移动网页 / H5 / PWA",
      "description": "响应式、触屏交互、离线支持、安装到桌面",
      "compatible_stacks": ["nextjs", "nuxt", "sveltekit", "vite-react", "vite-vue"]
    },
    {
      "id": "mobile-native",
      "name": "原生移动端",
      "description": "原生导航、离线优先、推送、设备 API",
      "compatible_stacks": ["react-native-expo", "flutter"]
    }
